# ── Required ──────────────────────────────────────────────

# API key for authenticating dashboard → backend requests
# Generate one with: cd backend && npm run generate-key
PAVER_API_KEY=

# Google Places API key (used for scanning businesses)
# Get one at: https://console.cloud.google.com/apis/credentials
# Required APIs: Places API (New)
GOOGLE_PLACES_API_KEY=

# ── Cloudflare Pages (optional, for deploying previews) ──

CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_PROJECT_NAME=paver

# ── Branding (shown on generated preview sites) ──────────

COMPANY_NAME=Your Company
COMPANY_PHONE=(555) 000-0000
COMPANY_EMAIL=hello@example.com
COMPANY_WEBSITE=example.com
COMPANY_BOOKING_URL=
SITE_PRICE=$499
SITE_DESCRIPTION=One-time setup • Includes 1 year of hosting • Custom design
